# Supabase — criar projeto em https://supabase.com e copiar valores
# Copiar para .env antes de executar
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Opcional: documentos da área reservada no disco do servidor (PHP em public/documentos-api.php)
# em vez do Storage Supabase. Ver docs/CPANEL-DOCUMENTOS.md
# VITE_DOCUMENTOS_API=/documentos-api.php

# Opcional: para scripts (ex: create-admin.js). Obter em Settings → API → service_role
# NUNCA expor no frontend
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
